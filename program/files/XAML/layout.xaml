                                        <TextBlock Grid.Row="1" Text="Fixes unresponsive or un-cancelable printing tasks. Automatically stops the Spooler service, forcefully clears stuck raw/shd files from the system spool folder, and restarts the process." Foreground="{StaticResource TextDim}" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,25" MinHeight="75"/>
                                        <Button x:Name="BTN_RUN_BUGFIX_5" Grid.Row="2" Content="Run Fix" Style="{StaticResource PrimaryBlueBtn}" Height="38" FontSize="13" FontWeight="Bold" HorizontalAlignment="Stretch"/>
