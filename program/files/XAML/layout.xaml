            <Setter Property="BorderBrush" Value="#3D2424" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#362424" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#4F3030" />
                                <Setter Property="Foreground" Value="#F29090" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E1010" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" ClipToBounds="True">
        <Grid ClipToBounds="True">
            <Grid IsHitTestVisible="False">
                <Border Background="{StaticResource AppShellBg}"/>
                <Ellipse Width="820" Height="820" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-280,-280,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#1800B4DB" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="0.72"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect><BlurEffect Radius="85"/></Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="760" Height="760" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-260,-260">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#103B82F6" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="0.70"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect><BlurEffect Radius="90"/></Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="1100" Height="700" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.9">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#12101820" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="0.78"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>
        <Grid x:Name="ROOT_GRID" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderShell}" BorderThickness="0,0,1,0" CornerRadius="12,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="98"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="22,0,0,0" VerticalAlignment="Center">
                        <Image x:Name="IMG_LOGO" Width="50" Height="50" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Platinum+" Foreground="#FFF" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="v0.3.1 (alpha)" Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>



                    <Grid Grid.Row="1" x:Name="NAV_CONTAINER" ClipToBounds="True">
                        <ScrollViewer x:Name="NAV_SCROLL"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Background="Transparent"
                                      Focusable="False"
                                      PanningMode="VerticalOnly">
                            <StackPanel x:Name="NAV_STACK" Margin="10,0,10,12">
                        <Border Height="3" Background="{StaticResource AccentGradient}" CornerRadius="1.5" Margin="0,4,0,12" SnapsToDevicePixels="True"/>
                        <TextBlock Text="GENERAL" Foreground="#7B8498" FontSize="11" FontWeight="SemiBold" Margin="15,8,0,2"/>
                        <Button x:Name="NAV_HOME" Style="{StaticResource NavBtn}">
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="IMG_HOME" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Home" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NAV_RESTORE" Style="{StaticResource NavBtn}">
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="IMG_RESTORE_NAV" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Backup &amp; Restore" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NAV_BUGFIX" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_BUGFIX_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Bug Fix" VerticalAlignment="Center"/></StackPanel></Button>
                        <TextBlock Text="SYSTEM" Foreground="#7B8498" FontSize="11" FontWeight="SemiBold" Margin="15,14,0,2"/>
                        <Button x:Name="NAV_SERVICE" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_SERVICE_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Service Manager" VerticalAlignment="Center"/></StackPanel></Button>
                        <Button x:Name="NAV_DEBLOAT" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_DEBLOAT_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="System Debloat" VerticalAlignment="Center"/></StackPanel></Button>
                        <Button x:Name="NAV_SYS_TWEAKS" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_SYSTWEAKS_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="System Tweaks" VerticalAlignment="Center"/></StackPanel></Button>
                        <TextBlock Text="HARDWARE" Foreground="#7B8498" FontSize="11" FontWeight="SemiBold" Margin="15,14,0,2"/>
                        <Button x:Name="NAV_CPU" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_CPU_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="CPU Tweaks" VerticalAlignment="Center"/></StackPanel></Button>
                        <Button x:Name="NAV_GPU" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_GPU_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="GPU Tweaks" VerticalAlignment="Center"/></StackPanel></Button>
                        <Button x:Name="NAV_RAM" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_RAM_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="RAM Tweaks" VerticalAlignment="Center"/></StackPanel></Button>
                        <TextBlock Text="ADDITIONAL" Foreground="#7B8498" FontSize="11" FontWeight="SemiBold" Margin="15,14,0,2"/>
                        <Button x:Name="NAV_DISK" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_DISK_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Disk Optimization" VerticalAlignment="Center"/></StackPanel></Button>
                        <Button x:Name="NAV_NET" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_NET_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Network Optimization" VerticalAlignment="Center"/></StackPanel></Button>
                        <Button x:Name="NAV_INPUT" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_INPUT_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Input Optimization" VerticalAlignment="Center"/></StackPanel></Button>
                        <TextBlock Text="SOFTWARE" Foreground="#7B8498" FontSize="11" FontWeight="SemiBold" Margin="15,14,0,2"/>
                        <Button x:Name="NAV_GAME" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_GAME_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Apps Optimization" VerticalAlignment="Center"/></StackPanel></Button>
                        <TextBlock Text="ABOUT" Foreground="#7B8498" FontSize="11" FontWeight="SemiBold" Margin="15,14,0,2"/>
                        <Button x:Name="NAV_ABOUT" Style="{StaticResource NavBtn}"><StackPanel Orientation="Horizontal"><Image x:Name="IMG_ABOUT_NAV" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="About" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>
                        </ScrollViewer>
                        <Canvas IsHitTestVisible="False">
                            <Border x:Name="SidebarSelector" Width="3" Height="24" Background="{StaticResource AccentGradient}" CornerRadius="2">
                                <Border.Effect><DropShadowEffect Color="#00B4DB" BlurRadius="8" Opacity="0.8" ShadowDepth="0"/></Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="SelectorTransform" Y="-100"/>
                                </Border.RenderTransform>
                            </Border>
                        </Canvas>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Background="Transparent">
                <!-- SHARED WINDOW CONTROLS -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,35,0" Panel.ZIndex="1000">
                    <Button x:Name="BTN_MIN" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Width="28" Height="28" FontSize="10" FontWeight="Bold" Style="{StaticResource WindowControlButtonStyle}" Margin="0,0,4,0" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="BTN_MAX" Content="&#xE739;" FontFamily="Segoe MDL2 Assets" Width="28" Height="28" FontSize="10" FontWeight="Bold" Style="{StaticResource WindowControlButtonStyle}" Margin="0,0,4,0" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="BTN_EXIT" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Width="28" Height="28" FontSize="10" FontWeight="Bold" Style="{StaticResource CloseButtonStyle}" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>

                <Grid x:Name="VIEW_MAIN" Opacity="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="280"/>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Grid.RenderTransform>

                <Grid Grid.Row="0" Margin="30,0">
                </Grid>

                <Grid Grid.Row="1" Margin="35,20,35,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-82,0,0">
                        <Grid Width="230" Height="218" HorizontalAlignment="Center" Margin="0,0,0,4" SnapsToDevicePixels="True">
                            <Ellipse Width="220" Height="200" Fill="{StaticResource HomeLogoAura}" Opacity="0.95" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="26"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Image x:Name="IMG_LOGO_MAIN" Width="190" Height="190" RenderOptions.BitmapScalingMode="HighQuality" CacheMode="BitmapCache" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.Effect><DropShadowEffect Color="#00B4DB" BlurRadius="36" Opacity="0.58" ShadowDepth="0"/></Image.Effect>
                            </Image>
                        </Grid>
                        <TextBlock Text="Welcome to Platinum+ Optimizer" Foreground="#FFF" FontSize="44" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-8,0,0">
                            <TextBlock.Effect><DropShadowEffect Color="#00B4DB" BlurRadius="20" Opacity="0.3" ShadowDepth="0"/></TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Performance, Optimization, and Troubleshooting All in One" Foreground="{StaticResource TextDim}" FontSize="16" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                </Grid>

                <UniformGrid Grid.Row="2" Columns="4" Margin="25,10,25,0">
                    <!-- CARD 1: CPU -->
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="12" Margin="5,0">
                        <Grid>
                            <Border CornerRadius="12" VerticalAlignment="Bottom" Height="80" Background="{StaticResource GlowGradCpu}"/>
                            <Grid Margin="15">
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Background="#232733" Width="48" Height="48" CornerRadius="8" VerticalAlignment="Center">
                                            <Image x:Name="IMG_CPU_CARD" Width="32" Height="32" VerticalAlignment="Center" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="TXT_CPU_NAME" Text="..." Foreground="#FFF" FontSize="11" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TXT_TEMP_CPU_CARD" Text="Temp: -- &#176;C" Foreground="{StaticResource HomeCpuColor}" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TXT_CPU" Text="0" Foreground="#FFF" FontSize="36" FontWeight="Bold"/>
                                        <TextBlock Text="%" Foreground="#FFF" FontSize="18" FontWeight="SemiBold" Margin="2,0,0,8" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                </StackPanel>
                                <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="60" Height="60">
                                    <Ellipse Stroke="#1A1B20" StrokeThickness="2" />
                                    <Ellipse x:Name="ARC_CPU" Stroke="{StaticResource HomeCpuColor}" StrokeThickness="2" StrokeDashArray="0 250" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform><RotateTransform Angle="140"/></Ellipse.RenderTransform>
                                    </Ellipse>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="4" Height="4" Fill="{StaticResource HomeCpuColor}">
                                            <Ellipse.Effect><DropShadowEffect Color="#2563EB" BlurRadius="6" Opacity="1" ShadowDepth="0"/></Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse Width="2" Height="2" Fill="{StaticResource BgCard}"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- CARD 2: RAM -->
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="12" Margin="5,0">
                        <Grid>
                            <Border CornerRadius="12" VerticalAlignment="Bottom" Height="80" Background="{StaticResource GlowGradRam}"/>
                            <Grid Margin="15">
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Background="#232733" Width="48" Height="48" CornerRadius="8" VerticalAlignment="Center">
                                            <Image x:Name="IMG_RAM_CARD" Width="32" Height="32" VerticalAlignment="Center" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="TXT_RAM_USED_TOTAL" Text="... / ... GB" Foreground="#FFF" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="Memory Usage" Foreground="{StaticResource TextDim}" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TXT_RAM" Text="0" Foreground="#FFF" FontSize="36" FontWeight="Bold"/>
                                        <TextBlock Text="%" Foreground="#FFF" FontSize="18" FontWeight="SemiBold" Margin="2,0,0,8" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                </StackPanel>
                                <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="60" Height="60">
                                    <Ellipse Stroke="#1A1B20" StrokeThickness="2" />
                                    <Ellipse x:Name="ARC_RAM" Stroke="{StaticResource HomeRamColor}" StrokeThickness="2" StrokeDashArray="0 250" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform><RotateTransform Angle="140"/></Ellipse.RenderTransform>
                                    </Ellipse>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="4" Height="4" Fill="{StaticResource HomeRamColor}">
                                            <Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="6" Opacity="1" ShadowDepth="0"/></Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse Width="2" Height="2" Fill="{StaticResource BgCard}"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- CARD 3: GPU -->
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="12" Margin="5,0">
                        <Grid>
                            <Border CornerRadius="12" VerticalAlignment="Bottom" Height="80" Background="{StaticResource GlowGradGpu}"/>
                            <Grid Margin="15">
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Background="#232733" Width="48" Height="48" CornerRadius="8" VerticalAlignment="Center">
                                            <Image x:Name="IMG_GPU_CARD" Width="32" Height="32" VerticalAlignment="Center" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="TXT_GPU_NAME" Text="..." Foreground="#FFF" FontSize="11" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TXT_TEMP_GPU_CARD" Text="Temp: -- &#176;C" Foreground="{StaticResource HomeGpuColor}" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TXT_GPU_USE" Text="0" Foreground="#FFF" FontSize="36" FontWeight="Bold"/>
                                        <TextBlock Text="%" Foreground="#FFF" FontSize="18" FontWeight="SemiBold" Margin="2,0,0,8" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                </StackPanel>
                                <Grid HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="60" Height="60">
                                    <Ellipse Stroke="#1A1B20" StrokeThickness="2" />
                                    <Ellipse x:Name="ARC_GPU" Stroke="{StaticResource HomeGpuColor}" StrokeThickness="2" StrokeDashArray="0 250" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform><RotateTransform Angle="140"/></Ellipse.RenderTransform>
                                    </Ellipse>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="4" Height="4" Fill="{StaticResource HomeGpuColor}">
                                            <Ellipse.Effect><DropShadowEffect Color="#8B5CF6" BlurRadius="6" Opacity="1" ShadowDepth="0"/></Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse Width="2" Height="2" Fill="{StaticResource BgCard}"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- CARD 4: NETWORK -->
                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="12" Margin="5,0">
                        <Grid>
                            <Border CornerRadius="12" VerticalAlignment="Bottom" Height="80" Background="{StaticResource GlowGradNet}"/>
                            <Grid Margin="15">
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Background="#232733" Width="48" Height="48" CornerRadius="8" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE839;" FontFamily="Segoe MDL2 Assets" Foreground="#FFF" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="TXT_NET_NAME" Text="..." Foreground="#FFF" FontSize="11" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                            <TextBlock Text="Network I/O" Foreground="{StaticResource TextDim}" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,5">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource HomeNetColor}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TXT_NET_DN" Text="0.00 Mbps" Foreground="#FFF" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource HomeNetColor}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TXT_NET_UP" Text="0.00 Mbps" Foreground="#FFF" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- BOTTOM MONITOR ROW -->
                <Grid Grid.Row="3" Margin="25,15,25,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LIVE PERFORMANCE GRAPH -->
                    <Border Grid.Column="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="12" Margin="5,0" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <Border Background="#232733" Width="30" Height="30" CornerRadius="6" Margin="0,0,10,0">
                                    <Image x:Name="IMG_CHART" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Text="Live Performance History (60s)" Foreground="#FFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="30,0,0,0" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource GraphCpuColor}" Margin="0,0,5,0"/><TextBlock Text="CPU" Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource GraphRamColor}" Margin="0,0,5,0"/><TextBlock Text="RAM" Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource GraphGpuColor}" Margin="0,0,5,0"/><TextBlock Text="GPU" Foreground="{StaticResource TextDim}" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="0,0,0,15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderBrush="#262936" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
                                    <Border Grid.Row="1" BorderBrush="#262936" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
                                    <Border Grid.Row="2" BorderBrush="#262936" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
                                    <Border Grid.Row="3" BorderBrush="#262936" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
                                    <Border Grid.Row="3" BorderBrush="#262936" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                    <Canvas x:Name="CANVAS_GRAPH" Grid.RowSpan="4" ClipToBounds="True">
                                        <Polyline x:Name="LINE_CPU_GRAPH" Stroke="{StaticResource GraphCpuColor}" StrokeThickness="2" StrokeLineJoin="Round"/>
                                        <Polyline x:Name="LINE_RAM_GRAPH" Stroke="{StaticResource GraphRamColor}" StrokeThickness="2" StrokeLineJoin="Round"/>
                                        <Polyline x:Name="LINE_GPU_GRAPH" Stroke="{StaticResource GraphGpuColor}" StrokeThickness="2" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Grid>

                                <Grid Grid.Column="1" Margin="0,0,0,15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="100%" Foreground="#555" FontSize="9" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,-5,0,0"/>
                                    <TextBlock Grid.Row="1" Text="75%" Foreground="#555" FontSize="9" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,-5,0,0"/>
                                    <TextBlock Grid.Row="2" Text="50%" Foreground="#555" FontSize="9" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,-5,0,0"/>
                                    <TextBlock Grid.Row="3" Text="25%" Foreground="#555" FontSize="9" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,-5,0,0"/>
                                    <TextBlock Grid.Row="3" Text="0%" Foreground="#555" FontSize="9" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-1"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- SYSTEM DETAILS -->
                    <Border Grid.Column="1" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="12" Margin="5,0" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <Border Background="#232733" Width="30" Height="30" CornerRadius="6" Margin="0,0,10,0">
                                    <Image x:Name="IMG_SYSTEM" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Text="System Details" Foreground="#FFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="OS" Foreground="{StaticResource TextDim}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TXT_OS_NAME" Text="..." Foreground="#FFF" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                    </Grid>
                                    
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="Uptime" Foreground="{StaticResource TextDim}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TXT_UPTIME" Text="00:00:00" Foreground="{StaticResource AccentBlue}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="Motherboard" Foreground="{StaticResource TextDim}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TXT_MB_NAME" Text="..." Foreground="#FFF" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                    </Grid>
                                    
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="Temperatures" Foreground="{StaticResource TextDim}" FontSize="10" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock x:Name="TXT_TEMP_CPU" Text="CPU: -- &#176;C" Foreground="{StaticResource HomeCpuColor}" FontSize="11" FontWeight="Medium" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="TXT_TEMP_GPU" Text="GPU: -- &#176;C" Foreground="{StaticResource HomeGpuColor}" FontSize="11" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="Disk Temp" Foreground="{StaticResource TextDim}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TXT_SSD_TEMP" Text="-- &#176;C" Foreground="{StaticResource HomeDiskColor}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="GPU VRAM" Foreground="{StaticResource TextDim}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TXT_VRAM" Text="-- / -- GB" Foreground="{StaticResource HomeGpuColor}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <TextBlock x:Name="TXT_CPU_TEMP" Visibility="Collapsed"/>
                                    <TextBlock x:Name="TXT_GPU_TEMP" Visibility="Collapsed"/>

                                    <StackPanel Margin="0,5,0,15">
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock x:Name="TXT_DISK_VOL" Text="Drive C:" Foreground="{StaticResource TextDim}" FontSize="10"/>
                                            <TextBlock x:Name="TXT_DISK_USE" Text="..." Foreground="#FFF" FontSize="10" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Border Height="4" Background="#232733" CornerRadius="2">
                                            <Border x:Name="BAR_DISK" Width="0" Background="{StaticResource HomeDiskColor}" CornerRadius="2" HorizontalAlignment="Left"/>
                                        </Border>
                                        <TextBlock x:Name="TXT_DISK_FREE" Text="..." Foreground="{StaticResource TextDim}" FontSize="9" Margin="0,4,0,0" HorizontalAlignment="Right"/>
                                    </StackPanel>

                                    <Border BorderBrush="#262936" BorderThickness="0,1,0,0" Margin="0,0,0,10"/>
                                    
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Top CPU Processes" Foreground="{StaticResource TextDim}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TXT_PROCS" Text="0 Total" Foreground="#555" FontSize="10" HorizontalAlignment="Right"/>
                                    </Grid>
                                    
                                    <Grid Margin="0,0,0,4"><TextBlock x:Name="TXT_TOP_PROC_1_NAME" Text="..." Foreground="#FFF" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,0,40,0"/><TextBlock x:Name="TXT_TOP_PROC_1_VAL" Text="0.0%" Foreground="{StaticResource HomeCpuColor}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right"/></Grid>
                                    <Grid Margin="0,0,0,4"><TextBlock x:Name="TXT_TOP_PROC_2_NAME" Text="..." Foreground="#CCC" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,0,40,0"/><TextBlock x:Name="TXT_TOP_PROC_2_VAL" Text="0.0%" Foreground="{StaticResource HomeCpuColor}" FontSize="10" HorizontalAlignment="Right"/></Grid>
                                    <Grid Margin="0,0,0,4"><TextBlock x:Name="TXT_TOP_PROC_3_NAME" Text="..." Foreground="#AAA" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,0,40,0"/><TextBlock x:Name="TXT_TOP_PROC_3_VAL" Text="0.0%" Foreground="{StaticResource HomeCpuColor}" FontSize="10" HorizontalAlignment="Right"/></Grid>
                                    <Grid Margin="0,0,0,4"><TextBlock x:Name="TXT_TOP_PROC_4_NAME" Text="..." Foreground="#888" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,0,40,0"/><TextBlock x:Name="TXT_TOP_PROC_4_VAL" Text="0.0%" Foreground="{StaticResource HomeCpuColor}" FontSize="10" HorizontalAlignment="Right"/></Grid>
                                    <Grid Margin="0,0,0,4"><TextBlock x:Name="TXT_TOP_PROC_5_NAME" Text="..." Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,0,40,0"/><TextBlock x:Name="TXT_TOP_PROC_5_VAL" Text="0.0%" Foreground="{StaticResource HomeCpuColor}" FontSize="10" HorizontalAlignment="Right"/></Grid>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                </Grid>

            <!-- BACKUP VIEW -->
            <Grid Grid.Column="1" x:Name="VIEW_BACKUP" Visibility="Hidden" Opacity="0" Background="Transparent">
                <Grid.RenderTransform><TranslateTransform Y="0"/></Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="35,35,35,0" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                    <StackPanel Margin="0,0,0,25" HorizontalAlignment="Left">
                        <TextBlock Text="Backup &amp; Restore Management" Foreground="#FFF" FontSize="32" FontWeight="Bold" Margin="0,0,0,6" HorizontalAlignment="Left"/>
                        <TextBlock Text="Create, manage, and restore complete system backups to protect your configuration, settings, and important data. Quickly recover your system whenever needed." Foreground="{StaticResource TextDim}" FontSize="15" TextWrapping="Wrap" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <Border Background="#1A1813" BorderBrush="#50D88A35" BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,0,0,20" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2A241C" Width="44" Height="44" CornerRadius="8" VerticalAlignment="Top">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#D88A35" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="WARNING: before proceeding, create a restore point or registry backup to avoid system issues. This tool backs up all changes - restoring here will reset all options, so they must be reapplied. For issues with specific modified/disabled features, use the revert in the dedicated sections, not here." Foreground="#D1B9A1" FontSize="14" FontWeight="Medium" TextWrapping="Wrap" VerticalAlignment="Center" LineHeight="22" Margin="20,0,0,0"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <ScrollViewer Grid.Row="1" x:Name="SCROLL_BACKUP" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent" PanningMode="None">
                    <Grid x:Name="BACKUP_CONTENT" Background="Transparent" MinHeight="{Binding ViewportHeight, ElementName=SCROLL_BACKUP}" MinWidth="{Binding ViewportWidth, ElementName=SCROLL_BACKUP}">
                        <Grid Margin="35,0,35,40" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="25"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- LEFT CARD: RESTORE POINTS -->
                            <Border Grid.Column="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="12" Padding="34,35,34,40">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" Background="#232733" BorderBrush="#2A2F3D" BorderThickness="1" CornerRadius="10" Width="48" Height="48" VerticalAlignment="Center">
                                            <Image x:Name="IMG_RESTORE" Width="26" Height="26" VerticalAlignment="Center" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                            <TextBlock Text="System Restore Point" Foreground="#FFF" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Border x:Name="BTN_INFO_RP" Width="20" Height="20" Background="#14171E" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="10" Cursor="Hand" ToolTip="Click for details" VerticalAlignment="Center" Margin="8,2,0,0">
                                                <TextBlock Text="?" Foreground="{StaticResource TextDim}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button x:Name="BTN_CLEAR_RP" Content="Refresh" Width="90" Style="{StaticResource SecondaryDarkBtn}" Margin="0,0,12,0" Height="40"/>
                                            <Button x:Name="BTN_DO_CREATE_RP" Content="Create Snapshot +" Width="140" Style="{StaticResource PrimaryBlueBtn}" Height="40"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Rectangle Height="1" Fill="#1C1D24" Margin="0,30,0,30"/>
                                    <TextBlock Text="Restore point name" Foreground="{StaticResource TextDim}" FontSize="13" FontWeight="Medium" Margin="2,0,0,8"/>
                                    <Border Background="#181A21" BorderBrush="#2A2F3D" BorderThickness="1" CornerRadius="8" Height="48" Margin="0,0,0,30">
                                        <TextBox x:Name="INP_RP_NAME" MaxLength="30" Text="PlatinumPoint" Background="Transparent" Foreground="#FFF" BorderThickness="0" Padding="15,0" FontSize="15" VerticalContentAlignment="Center" CaretBrush="#00B4DB" SelectionBrush="#00B4DB" SelectionOpacity="0.5"/>
                                    </Border>
                                    <TextBlock Text="Restore from existing snapshot" Foreground="{StaticResource TextDim}" FontSize="13" FontWeight="Medium" Margin="2,0,0,8"/>
                                    <ListBox x:Name="LIST_RP" Height="160" Background="#181A21" Foreground="#FFF" BorderBrush="#2A2F3D" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,0,0,30" Padding="8" FontSize="14" ItemContainerStyle="{StaticResource BackupListItem}"/>
                                    <Grid Margin="0,0,0,30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" x:Name="BTN_DO_APPLY_RP" Content="Execute Rollback" Style="{StaticResource PrimaryBlueBtn}" Height="44" IsEnabled="False"/>
                                        <Button Grid.Column="2" x:Name="BTN_DO_DEL_RP" Content="Delete Target" Style="{StaticResource DangerRedBtn}" Height="44" IsEnabled="False"/>
                                    </Grid>
                                    <StackPanel>
                                        <TextBlock Text="Why Create a Restore Point?" Foreground="#FFF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#232733" BorderBrush="#2A2F3D" BorderThickness="1" CornerRadius="6" Width="24" Height="24" VerticalAlignment="Top" Margin="0,2,0,0">
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#00B4DB" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Reverts your system to the exact state captured at creation; all subsequent changes, updates, or configurations will be permanently lost." Foreground="{StaticResource TextDim}" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="12,2,0,0"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#232733" BorderBrush="#2A2F3D" BorderThickness="1" CornerRadius="6" Width="24" Height="24" VerticalAlignment="Top" Margin="0,2,0,0">
                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#D88A35" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Always create a fresh restore point before major optimizations or system modifications to ensure a reliable rollback path." Foreground="#88D4E8" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" LineHeight="18" Margin="12,2,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- RIGHT CARD: REGISTRY BACKUP -->
                            <Border Grid.Column="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="12" Padding="34,35,34,40">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" Background="#232733" BorderBrush="#2A2F3D" BorderThickness="1" CornerRadius="10" Width="48" Height="48" VerticalAlignment="Center">
                                            <Image x:Name="IMG_REGISTRY" Width="26" Height="26" VerticalAlignment="Center" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                                            <TextBlock Text="Registry Backup" Foreground="#FFF" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Border x:Name="BTN_INFO_REG" Width="20" Height="20" Background="#14171E" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="10" Cursor="Hand" ToolTip="Click for details" VerticalAlignment="Center" Margin="8,2,0,0">
                                                <TextBlock Text="?" Foreground="{StaticResource TextDim}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button x:Name="BTN_CLEAR_REG" Content="Refresh" Width="90" Style="{StaticResource SecondaryDarkBtn}" Margin="0,0,12,0" Height="40"/>
                                            <Button x:Name="BTN_DO_CREATE_REG" Content="Export Registry +" Width="140" Style="{StaticResource PrimaryBlueBtn}" Height="40"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Rectangle Height="1" Fill="#1C1D24" Margin="0,30,0,30"/>
                                    <TextBlock Text="Registry dump name" Foreground="{StaticResource TextDim}" FontSize="13" FontWeight="Medium" Margin="2,0,0,8"/>
                                    <Border Background="#181A21" BorderBrush="#2A2F3D" BorderThickness="1" CornerRadius="8" Height="48" Margin="0,0,0,30">
                                        <TextBox x:Name="INP_REG_NAME" MaxLength="30" Text="PlatinumReg" Background="Transparent" Foreground="#FFF" BorderThickness="0" Padding="15,0" FontSize="15" VerticalContentAlignment="Center" CaretBrush="#00B4DB" SelectionBrush="#00B4DB" SelectionOpacity="0.5"/>
                                    </Border>
                                    <TextBlock Text="Restore registry tree from existing dump" Foreground="{StaticResource TextDim}" FontSize="13" FontWeight="Medium" Margin="2,0,0,8"/>
                                    <ListBox x:Name="LIST_REG" Height="160" Background="#181A21" Foreground="#FFF" BorderBrush="#2A2F3D" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,0,0,30" Padding="8" FontSize="14" ItemContainerStyle="{StaticResource BackupListItem}"/>
                                    <Grid Margin="0,0,0,30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" x:Name="BTN_DO_APPLY_REG" Content="Force Merge Registry" Style="{StaticResource PrimaryBlueBtn}" Height="44" IsEnabled="False"/>
                                        <Button Grid.Column="2" x:Name="BTN_DO_DEL_REG" Content="Delete Target" Style="{StaticResource DangerRedBtn}" Height="44" IsEnabled="False"/>
                                    </Grid>
                                    <StackPanel>
                                        <TextBlock Text="Why Create a Registry Backup?" Foreground="#FFF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#232733" BorderBrush="#2A2F3D" BorderThickness="1" CornerRadius="6" Width="24" Height="24" VerticalAlignment="Top" Margin="0,2,0,0">
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#00B4DB" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Overwrites existing registry keys and subkeys, reverting any system or application settings modified after the backup was saved." Foreground="{StaticResource TextDim}" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="12,2,0,0"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#232733" BorderBrush="#2A2F3D" BorderThickness="1" CornerRadius="6" Width="24" Height="24" VerticalAlignment="Top" Margin="0,2,0,0">
                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#D88A35" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Serves as a critical offline recovery file for boot-loop scenarios, restorable manually via the Windows Recovery Environment or command prompt." Foreground="#88D4E8" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" LineHeight="18" Margin="12,2,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- BUGFIX VIEW -->
            <Grid Grid.Column="1" x:Name="VIEW_BUGFIX" Visibility="Hidden" Opacity="0" Background="Transparent">
                <Grid.RenderTransform><TranslateTransform Y="0"/></Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Margin="35,35,49,0" HorizontalAlignment="Stretch" VerticalAlignment="Top">
