                                    </Grid>
                                </Border>
                                <!-- Option 2 -->
                                <Border x:Name="CARD_BUGFIX_2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="14" Margin="10,12" Padding="25">                            <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
