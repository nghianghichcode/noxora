                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg" Background="{TemplateBinding Background}" BorderBrush="#A16207" BorderThickness="1" CornerRadius="7" SnapsToDevicePixels="True">
