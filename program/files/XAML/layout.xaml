                                        <Button x:Name="BTN_RUN_BUGFIX_6" Grid.Row="2" Content="Run Fix" Style="{StaticResource PrimaryBlueBtn}" Height="38" FontSize="13" FontWeight="Bold" HorizontalAlignment="Stretch"/>
