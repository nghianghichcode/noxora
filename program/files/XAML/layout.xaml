                                                <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" Foreground="#00B4DB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Repair Print Spooler Service" Foreground="#FFF" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,8,0" VerticalAlignment="Center"/>
