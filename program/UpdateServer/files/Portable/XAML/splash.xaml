<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Platinum+ Optimizer Loading"
        Height="400" Width="600"
        AllowsTransparency="True" Background="Transparent"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Window.Resources>
        <!-- Glow gradient for background -->
        <RadialGradientBrush x:Key="GlowBrush" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
            <GradientStop Color="#1500B4DB" Offset="0"/>
            <GradientStop Color="#0000B4DB" Offset="1"/>
        </RadialGradientBrush>

        <LinearGradientBrush x:Key="ProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0088A8" Offset="0"/>
            <GradientStop Color="#00B4DB" Offset="0.48"/>
            <GradientStop Color="#58E6FF" Offset="1"/>
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="LogoAuraBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
            <GradientStop Color="#6A58E6FF" Offset="0"/>
            <GradientStop Color="#5200B4DB" Offset="0.42"/>
            <GradientStop Color="#18006782" Offset="0.74"/>
            <GradientStop Color="#0000B4DB" Offset="1"/>
        </RadialGradientBrush>
    </Window.Resources>
    
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Premium logo reveal -->
                    <DoubleAnimation Storyboard.TargetName="LogoRevealTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="10" To="0" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoStage"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.45"/>
                    <DoubleAnimation Storyboard.TargetName="LogoScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.92" To="1" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.22"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.92" To="1" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.22"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Lightweight continuous pulse -->
                    <DoubleAnimation Storyboard.TargetName="LogoPulse"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.985" To="1.075" BeginTime="0:0:0.6" Duration="0:0:1.15"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoPulse"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.985" To="1.075" BeginTime="0:0:0.6" Duration="0:0:1.15"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.38" To="0.82" BeginTime="0:0:0.6" Duration="0:0:1.15"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="14" To="30" BeginTime="0:0:0.6" Duration="0:0:1.15"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoAura"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.58" To="1" BeginTime="0:0:0.6" Duration="0:0:1.15"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoAuraScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.9" To="1.18" BeginTime="0:0:0.6" Duration="0:0:1.15"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoAuraScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.9" To="1.18" BeginTime="0:0:0.6" Duration="0:0:1.15"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- GPU-friendly progress fill: scale avoids layout recalculation -->
                    <DoubleAnimation Storyboard.TargetName="ProgressFillScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0" To="1" Duration="0:0:2.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ProgressShine"
                                     Storyboard.TargetProperty="X"
                                     From="-80" To="320" BeginTime="0:0:0.08" Duration="0:0:1.2"
                                     RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid x:Name="SPLASH_ROOT" Opacity="1">
        <!-- Border drop shadow effect -->
        <Border Background="#0E1015" CornerRadius="24" BorderBrush="#252A36" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#00B4DB" BlurRadius="30" Opacity="0.25" ShadowDepth="0"/>
            </Border.Effect>
            
            <Grid>
                <!-- Radial background glow -->
                <Rectangle Fill="{StaticResource GlowBrush}" Margin="2"/>
                
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Centered logo with premium pulse -->
                    <Grid x:Name="LogoStage" Width="184" Height="184" Margin="0,0,0,6" Opacity="0"
                          RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="LogoScale"/>
                                <TranslateTransform x:Name="LogoRevealTranslate"/>
                            </TransformGroup>
                        </Grid.RenderTransform>

                        <Ellipse x:Name="LogoAura" Width="172" Height="172" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Fill="{StaticResource LogoAuraBrush}" Opacity="0.65" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Effect>
                                <BlurEffect Radius="22"/>
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="LogoAuraScale"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="LogoPulse"/>
                            </Grid.RenderTransform>
                            <Image x:Name="IMG_SPLASH_LOGO" Width="160" Height="160" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" CacheMode="BitmapCache" RenderOptions.EdgeMode="Aliased">
                            <Image.Effect>
                                <DropShadowEffect x:Name="LogoGlow" Color="#00B4DB" BlurRadius="12" Opacity="0.32" ShadowDepth="0"/>
                            </Image.Effect>
                            </Image>
                        </Grid>
                    </Grid>
                    
                    <!-- App Title -->
                    <TextBlock Text="Platinum+" Foreground="White" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00B4DB" BlurRadius="10" Opacity="0.3" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    
                    <!-- Subtitle / Status -->
                    <TextBlock x:Name="TXT_SPLASH_STATUS" Text="Initializing Windows optimization..." Foreground="#545B6A" FontSize="11" FontWeight="Medium" Margin="0,8,0,30" HorizontalAlignment="Center"/>
                    
                    <!-- Custom Progress Bar -->
                    <Border Width="300" Height="6" Background="#181A21" CornerRadius="3" BorderBrush="#232733" BorderThickness="1" SnapsToDevicePixels="True">
                        <Grid ClipToBounds="True" CacheMode="BitmapCache" SnapsToDevicePixels="True">
                            <Border Width="298" Height="4" CornerRadius="2" HorizontalAlignment="Left" Background="#1800B4DB"/>
                            <Border x:Name="SPLASH_PROGRESS" Width="298" Height="4" Background="{StaticResource ProgressBrush}" CornerRadius="2"
                                    HorizontalAlignment="Left" RenderTransformOrigin="0,0.5" SnapsToDevicePixels="True">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="ProgressFillScale" ScaleX="0" ScaleY="1"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border Width="86" Height="4" CornerRadius="2" HorizontalAlignment="Left" Opacity="0.62"
                                    CacheMode="BitmapCache">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00FFFFFF" Offset="0"/>
                                        <GradientStop Color="#88EFFFFF" Offset="0.5"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <BlurEffect Radius="2"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ProgressShine"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
